APP_NAME=CouturePro
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=10

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Base de données ──────────────────────────────────────────────────────────
# Option A : SQLite (le plus simple, aucune install requise)
DB_CONNECTION=sqlite
# DB_DATABASE=/chemin/absolu/vers/database/database.sqlite

# Option B : MySQL local (si tu as MySQL installé)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=couturepro_local
# DB_USERNAME=root
# DB_PASSWORD=

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database

# ── Mail ─────────────────────────────────────────────────────────────────────
# Option A : log (les emails s'écrivent dans storage/logs — aucun serveur requis)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="dev@couturepro.local"
MAIL_FROM_NAME="CouturePro Dev"

# Option B : MailTrap (pour voir les vrais emails dans un dashboard web gratuit)
# MAIL_MAILER=smtp
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=<ton_user_mailtrap>
# MAIL_PASSWORD=<ton_pass_mailtrap>
# MAIL_FROM_ADDRESS="dev@couturepro.local"
# MAIL_FROM_NAME="CouturePro Dev"

# ── Paiement ─────────────────────────────────────────────────────────────────
PAYMENT_DEFAULT_PROVIDER=fedapay
FEDAPAY_API_KEY=sk_sandbox_iMFq2sz2KaW195VtPcpcxIz5
FEDAPAY_WEBHOOK_SECRET=
FEDAPAY_SANDBOX=true
FEDAPAY_RETURN_URL="${FRONTEND_URL}/paiement/retour"
FEDAPAY_WEBHOOK_URL="${APP_URL}/api/webhooks/fedapay"

VITE_APP_NAME="${APP_NAME}"
